{
  "name": "@ai-support/widget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('esbuild').buildSync({entryPoints:['dist/widget.js'],bundle:true,format:'iife',globalName:'AISupportWidgetModule',outfile:'dist/widget.bundle.js',minify:true,footer:{js:'window.AISupportWidget=AISupportWidgetModule.AISupportWidget;'}})\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  }
}
